{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "base", "name": "Base", "color": "#FFFFFF" },
        { "slug": "contrast", "name": "Contrast", "color": "#0F172A" },
        { "slug": "primary", "name": "Primary", "color": "#0B5FFF" },
        { "slug": "secondary", "name": "Secondary", "color": "#14B8A6" },
        { "slug": "muted", "name": "Muted", "color": "#F3F4F6" }
      ]
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 6,
        "mediumStep": "1rem",
        "unit": "rem"
      }
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"IBM Plex Sans Arabic\", sans-serif",
          "name": "Arabic Sans",
          "slug": "arabic"
        },
        {
          "fontFamily": "Inter, system-ui, sans-serif",
          "name": "Latin Sans",
          "slug": "latin"
        }
      ],
      "fluid": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--arabic)",
      "lineHeight": "1.7"
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "border": {
          "radius": "0.5rem"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
