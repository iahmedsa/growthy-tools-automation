{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "base", "name": "Base", "color": "#FFFFFF" },
        { "slug": "contrast", "name": "Contrast", "color": "#0F172A" },
        { "slug": "primary", "name": "Primary", "color": "#0B5FFF" },
        { "slug": "secondary", "name": "Secondary", "color": "#14B8A6" },
        { "slug": "muted", "name": "Muted", "color": "#F8FAFC" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "vw", "%"],
      "spacingSizes": [
        { "slug": "xs", "name": "XS", "size": "0.5rem" },
        { "slug": "sm", "name": "SM", "size": "0.75rem" },
        { "slug": "md", "name": "MD", "size": "1rem" },
        { "slug": "lg", "name": "LG", "size": "1.5rem" },
        { "slug": "xl", "name": "XL", "size": "2rem" },
        { "slug": "2xl", "name": "2XL", "size": "3rem" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"IBM Plex Sans Arabic\", sans-serif",
          "name": "Arabic Sans",
          "slug": "arabic"
        },
        {
          "fontFamily": "Inter, system-ui, sans-serif",
          "name": "Latin Sans",
          "slug": "latin"
        }
      ],
      "fontSizes": [
        { "slug": "sm", "size": "0.9rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.25rem", "name": "Large" },
        { "slug": "xl", "size": "2rem", "name": "XL" },
        { "slug": "2xl", "size": "2.6rem", "name": "2XL" }
      ],
      "fluid": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--arabic)",
      "lineHeight": "1.8"
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "border": {
          "radius": "0.5rem"
        },
        "spacing": {
          "padding": {
            "top": "0.7rem",
            "right": "1.2rem",
            "bottom": "0.7rem",
            "left": "1.2rem"
          }
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
